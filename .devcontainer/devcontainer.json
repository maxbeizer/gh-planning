{
  "name": "gh-helm-daemon",
  "image": "mcr.microsoft.com/devcontainers/go:1.24",
  "postStartCommand": "go build -o /tmp/gh-helm . && /tmp/gh-helm project daemon --max-per-hour 3",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "codespaces": {
      "machine": "basicLinux32gb"
    }
  }
}
